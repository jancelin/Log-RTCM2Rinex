# ──────────────────────────────────────────────────────────────────────────────
# config/webstat.htpasswd  — Basic Auth pour /webstat/
#
# Ce fichier doit exister AVANT le premier démarrage du container "web".
# Il est monté en read-only dans nginx : ./config/webstat.htpasswd → /etc/nginx/.htpasswd-webstat
#
# ── Génération (méthode recommandée) ──────────────────────────────────────────
#
#   Avec le script intégré (demande le mot de passe interactivement) :
#     ./scripts/gen-webstat-htpasswd.sh webstat
#
#   Manuellement avec apache2-utils :
#     sudo apt-get install -y apache2-utils     # Debian/Ubuntu
#     htpasswd -c config/webstat.htpasswd webstat
#
#   Avec Python (pas de dépendance externe) :
#     python3 -c "
#     import crypt, getpass, sys
#     u = sys.argv[1]
#     p = getpass.getpass('Password: ')
#     print(u + ':' + crypt.crypt(p, crypt.mksalt(crypt.METHOD_SHA512)))
#     " webstat >> config/webstat.htpasswd
#
#   Dans un container Alpine (si pas de htpasswd en local) :
#     docker run --rm -it --entrypoint htpasswd httpd:alpine -nB webstat
#     # Copier la ligne affichée dans config/webstat.htpasswd
#
# ── Ajouter un second utilisateur ─────────────────────────────────────────────
#   htpasswd config/webstat.htpasswd autreuser   # sans -c pour ne pas écraser
#
# ── Appliquer les changements ──────────────────────────────────────────────────
#   docker compose restart web
#
# ── Exemple de ligne valide ────────────────────────────────────────────────────
# webstat:$apr1$xyz...$hashedpassword
# ──────────────────────────────────────────────────────────────────────────────
